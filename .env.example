# --- Required ---
# Bot token from https://discord.com/developers/applications (Bot → Reset Token)
DISCORD_TOKEN=your-bot-token-here

# Application (Client) ID of your Discord application
DISCORD_CLIENT_ID=your-client-id-here

# ID of the guild the bot runs in (enable Developer Mode, right-click server → Copy Server ID)
DISCORD_GUILD_ID=your-guild-id-here

# --- Optional ---
# Default channel ID for the pinned timezone sheet. Can also be set at runtime via /timezone post-sheet channel:#name
PINNED_CHANNEL_ID=

# Path to the SQLite database file (created automatically)
DATABASE_PATH=./data/timezones.db
