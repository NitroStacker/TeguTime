{
  "name": "tegutime",
  "version": "0.2.0",
  "private": true,
  "description": "TeguTime — Game Jam OS for Discord. Monorepo containing the bot and shared packages.",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "pnpm --filter @tegutime/bot dev",
    "start": "pnpm --filter @tegutime/bot start",
    "register": "pnpm --filter @tegutime/bot register",
    "typecheck": "pnpm -r --parallel typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
